# Polling interval for live match data (ms)
POLL_INTERVAL_MS=10000

# Full sync interval (ms) - default 24 hours
FULL_SYNC_INTERVAL_MS=86400000

# Delay between ESPN API requests (ms) - avoid rate limits
ESPN_REQUEST_DELAY_MS=200

# SQLite database path
DB_PATH=./data/scoreboard.db

# Server port
PORT=3000

# CORS - use * for public access, or comma-separated origins
CORS_ORIGIN=*
